{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"dataSource": {
			"type": "object",
			"properties": {
				"type": {
					"type": "string"
				},
				"url": {
					"type": "string"
				}
			},
			"required": ["type"]
		},
		"bookLinkSource": {
			"enum": ["none", "openlibrary", "provider"]
		},
		"coverSource": {
			"enum": ["metadata", "none", "openlibrary"]
		},
		"dateFormat": {
			"enum": ["dd.mm.yyyy", "mm/dd/yyyy", "yyyy-mm-dd"]
		},
		"sections": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"label": {
						"type": "string"
					},
					"filter": {
						"type": "object",
						"properties": {
							"hasRating": {
								"type": "boolean"
							},
							"hasReview": {
								"type": "boolean"
							},
							"shelf": {
								"type": "string"
							}
						}
					},
					"mode": {
						"enum": ["3d", "covers", "list", "spines"]
					},
					"scale": {
						"type": "number",
						"maximum": 1.6,
						"minimum": 0.65
					},
					"showAuthor": {
						"type": "boolean"
					},
					"showRatings": {
						"type": "boolean"
					},
					"showReadDate": {
						"type": "boolean"
					},
					"showReviews": {
						"type": "boolean"
					},
					"sortBy": {
						"enum": ["addedAt", "addedAtAsc", "rating", "ratingAsc", "readAt", "readAtAsc"]
					},
					"spineBehavior": {
						"enum": ["hover", "open"]
					}
				},
				"required": ["label"]
			}
		},
		"showAttribution": {
			"type": "boolean"
		},
		"stylesheet": {
			"enum": ["cdn", "inline", "none"]
		},
		"theme": {
			"enum": ["auto", "dark", "light"]
		}
	},
	"required": ["dataSource"],
	"$id": "https://bookshelf.dawdle.space/schema/v0.1.0/schema.json",
	"title": "Bookshelf Config"
}
